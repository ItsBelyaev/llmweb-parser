# Скопируйте этот файл в .env и заполните ключи.
# Сервис автоматически выбирает LLM-провайдера: OpenAI приоритетнее,
# если задан OPENAI_API_KEY. Иначе используется Hugging Face.

# --- LLM провайдеры ------------------------------------------------------
# OpenAI (приоритет, GPT-4o-mini)
# OPENAI_API_KEY=sk-proj-your-key-here

# Hugging Face (fallback, бесплатно, Llama 3.1 8B)
HUGGINGFACE_API_KEY=hf_your_key_here
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_TEMPERATURE=0.0
HUGGINGFACE_MAX_TOKENS=1024

# --- Playwright / Fetcher / Interactor ----------------------------------
FETCH_TIMEOUT_MS=60000
FETCH_SETTLE_MS=2000
INTERACT_TIMEOUT_MS=15000

# --- HTML cleaner -------------------------------------------------------
MAX_HTML_CHARS=12000

# --- БД -----------------------------------------------------------------
DB_PATH=llmweb.db
